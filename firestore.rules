rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========
    
    // Check if user document exists and has admin role
    // Usa custom claims de Firebase Auth (más confiable y rápido)
    function isAdminOrSuperadmin() {
      return request.auth.token.role in ['admin', 'superadmin'];
    }
    
    // Get current user's tenantId
    function userTenantId() {
      return request.auth.token.tenantId;
    }

    // ========== TENANTS ==========
    // Configuración de cada tienda
    match /tenants/{tenantId} {
      // Leer: público (info básica de la tienda)
      allow read: if true;
      // Crear: denegado (superadmin lo hace por Cloud Function)
      allow create: if false;
      // Actualizar: solo admins del tenant
      allow update: if request.auth != null && isAdminOrSuperadmin() && userTenantId() == tenantId;
    }

    // ========== SERVICES ==========
    // Servicios que ofrece cada tenant
    match /services/{serviceId} {
      // Leer: público (para la tienda)
      allow read: if true;
      // Escribir: solo admin
      allow create, update, delete: if request.auth != null && isAdminOrSuperadmin();
    }

    // ========== BANNERS ==========
    // Banners de cada tenant
    match /banners/{bannerId} {
      // Leer: público
      allow read: if true;
      // Escribir: solo admin
      allow create, update, delete: if request.auth != null && isAdminOrSuperadmin();
    }

    // ========== USERS ==========
    // Usuarios administradores (rol y tenantId) - colección del sistema
    match /users/{userId} {
      // Leer: propio usuario O superadmin puede leer todos
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role == 'superadmin'
      );
      // Crear: denegado (Cloud Function)
      allow create: if false;
      // Update: denegado desde cliente
      allow update: if false;
    }

    // ========== CUSTOMERS ==========
    // Clientes registrados (datos sensibles)
    match /customers/{customerId} {
      // Leer: solo admins O el propio cliente
      allow read: if request.auth != null && (
        isAdminOrSuperadmin() ||
        request.auth.uid == customerId
      );
      // Auto-creación: permitir registro público
      allow create: if request.auth != null && request.auth.uid == customerId;
      // Update: admins O el propio cliente
      allow update: if request.auth != null && (
        isAdminOrSuperadmin() ||
        request.auth.uid == customerId
      );
    }

    // ========== RECARGAS ==========
    // Solicitudes de recarga de saldo
    match /recharges/{rechargeId} {
      // Leer: solo admins (cualquier tenant)
      allow read: if request.auth != null && isAdminOrSuperadmin();
      // Crear: cualquier usuario logueado
      allow create: if request.auth != null;
      // Update: solo admins (cualquier tenant por ahora)
      allow update: if request.auth != null && isAdminOrSuperadmin();
    }

    // ========== RULETA CONFIG ==========
    // Configuración de la ruleta por tenant
    match /rouletteConfig/{tenantId} {
      // Leer: público (para que los clientes vean la config)
      allow read: if true;
      // Crear/Actualizar: solo admins del tenant
      allow write: if request.auth != null && isAdminOrSuperadmin() && userTenantId() == tenantId;
    }
  }
}