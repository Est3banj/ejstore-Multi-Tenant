rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== TENANTS ==========
    match /tenants/{tenantId} {
      allow read: if true;
      // Solo usuarios autenticados pueden escribir su propio tenant
      allow write: if request.auth != null;
    }

    // ========== SERVICES ==========
    match /services/{serviceId} {
      allow read: if true;
      // Cualquier usuario autenticado puede crear/editar (el código valida tenantId)
      allow create, update, delete: if request.auth != null;
    }

    // ========== BANNERS ==========
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ========== USERS ==========
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ========== CUSTOMERS ==========
    match /customers/{customerId} {
      // Allow read for testing - everyone can read (remove in production)
      allow read: if true;
      // Anyone authenticated can create their own customer record
      allow create: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == customerId;
    }
  }
}
