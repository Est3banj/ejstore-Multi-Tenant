# Firebase Config - Obtener de Firebase Console > Project Settings
# NO incluir valores reales en el repo - usar secretos del sistema de build

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Environment (no cambiar - Vite lo maneja)
VITE_APP_ENV=development

# ==================== CLOUD FUNCTIONS ====================
# Configurar en Firebase: firebase functions:config:set telegram.bot_token="..." telegram.admin_chat_id="..."
# O usar variables de entorno del sistema de deployment
# TELEGRAM_BOT_TOKEN=your_bot_token
# ADMIN_CHAT_ID=your_admin_chat_id